// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/debian
{
  "name": "DxE ADB",

  // https://code.visualstudio.com/docs/devcontainers/create-dev-container#_use-docker-compose
  "dockerComposeFile": [
    "../server/compose.yaml",
    "./compose.extend.yaml",
    "./compose.workspace.yaml"
  ],
  "service": "devcontainer", // defined in dockerComposeFile
  "runServices": ["devcontainer", "mysql"], // defined in dockerComposeFile
  // Linked worktrees break if VS Code remounts the shared Git root at /workspace.
  "mountWorkspaceGitRoot": false,
  "workspaceFolder": "/workspace",
  "shutdownAction": "stopCompose",
  "remoteUser": "vscode",
  // Generate a per-worktree Compose override for the project name and mounts.
  "initializeCommand": "bash .devcontainer/write-workspace-compose.sh '${localWorkspaceFolder}'",

  // Features to add to the dev container. More info: https://containers.dev/features.
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": true,
      "azureDnsAutoDetection": true,
      "installDockerBuildx": true,
      "version": "latest",
      "dockerDashComposeVersion": "v2"
    },
    "ghcr.io/devcontainers/features/go:1": {
      // Please keep in sync with server/src/go.mod
      "version": "1.25.8",
      // Pin to avoid broken upstream "latest" releases (e.g. v2.12.1 had a
      // checksum mismatch on 2026-05-02).
      "golangciLintVersion": "2.11.4"
    },
    "ghcr.io/devcontainers/features/node:2": {
      "nodeGypDependencies": true,
      "version": "25" // Match version from Makefile REACT_FRONTEND_NODE_VERSION
    },
    "ghcr.io/jungaretti/features/make:1": {},
    "ghcr.io/rocker-org/devcontainer-features/apt-packages:1": {
      // mariadb-client package provides the `mysql` command for
      //     development / debugging purposes (not an app dependeny).
      // bash-completion is useful for entering git commands in the devcontainer
      //     and our .bashrc requires this.
      "packages": "mariadb-client,bash-completion"
    }
  },
  "customizations": {
    "vscode": {
      "settings": {
        // Bake the worktree folder name into the window title so two devcontainer
        // windows are distinguishable. ${localWorkspaceFolderBasename} is a
        // devcontainer variable substituted at container-create time with the
        // literal folder name; the rest are VS Code window.title variables
        // evaluated at runtime.
        "window.title": "${localWorkspaceFolderBasename} — ${activeEditorShort}${separator}${appName}"
      },
      "extensions": [
        "ms-vscode.makefile-tools",
        "golang.go",
        "Vue.volar",
        "GitHub.vscode-github-actions",
        "ms-vscode.vscode-typescript-next",
        "esbenp.prettier-vscode",
        "GitHub.vscode-pull-request-github",
        "vitest.explorer"
      ]
    }
  },

  // Use 'forwardPorts' to make a list of ports inside the container available locally.
  "forwardPorts": [8080 /* ADB main site (adb.dxe.io) */],

  // Configure tool-specific properties.
  // "customizations": {},

  "postCreateCommand": "bash /workspace/.devcontainer/post-create.sh",

  // Persist Claude Code config (settings, credentials) across container rebuilds.
  // Using ${devcontainerId} in the volume name scopes it to this project — each
  // project gets its own isolated volume rather than sharing one across all devcontainers
  // on the same Docker host.
  "mounts": [
    "source=claude-code-config-${devcontainerId},target=/home/vscode/.claude,type=volume"
  ]
}
