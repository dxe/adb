# Shared shell functions loaded by both:
#  * .bashrc for interactive non-login shells such as integrated terminal in VS Code
#  * .bash_profile for login shells, including non-interactive, for use by coding agents / LLMs

db() {
  mysql -u "$DB_USER" -h "$DB_HOST" -D "$DB_NAME" --password="$DB_PASSWORD" "$@"
}

adb() {
  go run /workspace/cli "$@"
}
