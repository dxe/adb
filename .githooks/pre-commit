#!/bin/sh

# Adapted from https://golang.org/misc/git/pre-commit
# Keep in sync with "make fmt".

gofiles=$(cd server && gofmt -l .)
# Pin the prettier version so the check matches the project (package.json) and
# CI, instead of whatever "latest" pnpx would download. Keep in sync with the
# "prettier" version in package.json.
webfiles=$(pnpx prettier@3.7.3 -l --cache --cache-strategy metadata .)
[ -z "$gofiles" -a -z "$webfiles" ] && exit 0

echo >&2 "Misformatted files:"
for fn in $gofiles $webfiles; do
  echo >&2 "  $fn"
done
echo >&2
echo >&2 "Please run: make fmt"

exit 1
